{
	"name": "omni-webui",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "npm run lint:frontend ; npm run lint:types",
		"lint:frontend": "eslint . --fix",
		"lint:types": "npm run check",
		"format": "biome format --write .",
		"i18n:parse": "i18next --config i18next-parser.config.ts && biome format .",
		"cy:open": "cypress open",
		"test:frontend": "vitest",
		"pyodide:fetch": "node scripts/prepare-pyodide.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.8.3",
		"@sveltejs/adapter-auto": "^3.2.2",
		"@sveltejs/adapter-static": "^3.0.2",
		"@sveltejs/kit": "^2.5.18",
		"@tailwindcss/typography": "^0.5.13",
		"@types/file-saver": "^2.0.7",
		"@types/uuid": "^10.0.0",
		"@typescript-eslint/eslint-plugin": "^7.14.1",
		"@typescript-eslint/parser": "^7.14.1",
		"autoprefixer": "^10.4.19",
		"cypress": "^13.12.0",
		"eslint": "^9.6.0",
		"eslint-plugin-cypress": "^3.3.0",
		"eslint-plugin-svelte": "^2.41.0",
		"globals": "^15.7.0",
		"i18next-parser": "^9.0.0",
		"postcss": "^8.4.39",
		"svelte": "^4.2.18",
		"svelte-check": "^3.8.4",
		"svelte-confetti": "^2.0.1",
		"tailwindcss": "^3.4.4",
		"tslib": "^2.6.3",
		"typescript": "^5.5.2",
		"typescript-eslint": "^7.14.1",
		"vite": "^5.3.2",
		"vitest": "^1.6.0"
	},
	"type": "module",
	"dependencies": {
		"@pyscript/core": "^0.4.53",
		"@sveltejs/adapter-node": "^5.2.0",
		"bits-ui": "^0.21.11",
		"dayjs": "^1.11.11",
		"eventsource-parser": "^1.1.2",
		"file-saver": "^2.0.5",
		"highlight.js": "^11.9.0",
		"i18next": "^23.11.5",
		"i18next-browser-languagedetector": "^8.0.0",
		"i18next-resources-to-backend": "^1.2.1",
		"idb": "^8.0.0",
		"js-sha256": "^0.11.0",
		"katex": "^0.16.10",
		"marked": "^13.0.1",
		"mermaid": "^10.9.1",
		"pyodide": "^0.26.1",
		"socket.io-client": "^4.7.5",
		"sortablejs": "^1.15.2",
		"svelte-sonner": "^0.3.24",
		"tippy.js": "^6.3.7",
		"uuid": "^10.0.0"
	}
}
