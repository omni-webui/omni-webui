{
	"name": "omni-webui",
	"version": "0.1.1",
	"private": true,
	"scripts": {
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "npm run lint:frontend ; npm run lint:types",
		"lint:frontend": "eslint . --fix",
		"lint:types": "npm run check",
		"format": "biome format --write .",
		"i18n:parse": "i18next --config i18next-parser.config.ts && biome format .",
		"cy:open": "cypress open",
		"test:frontend": "vitest",
		"pyodide:fetch": "node scripts/prepare-pyodide.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.8.1",
		"@sveltejs/adapter-auto": "^3",
		"@sveltejs/adapter-static": "^2.0.3",
		"@sveltejs/kit": "^2",
		"@tailwindcss/typography": "^0.5.10",
		"@types/bun": "latest",
		"@types/file-saver": "^2.0.7",
		"@types/uuid": "^9.0.8",
		"@typescript-eslint/eslint-plugin": "^6.17.0",
		"@typescript-eslint/parser": "^6.17.0",
		"autoprefixer": "^10.4.16",
		"cypress": "^13.8.1",
		"eslint": "^9",
		"eslint-plugin-cypress": "^3.3",
		"eslint-plugin-svelte": "^2.39",
		"globals": "^15.4.0",
		"i18next-parser": "^8.13.0",
		"postcss": "^8.4.31",
		"svelte": "^4.0.5",
		"svelte-check": "^3.4.3",
		"svelte-confetti": "^1.3.2",
		"tailwindcss": "^3.3.3",
		"tslib": "^2.4.1",
		"typescript": "^5.0.0",
		"typescript-eslint": "^7.13.0",
		"vite": "latest",
		"vitest": "^1.6.0"
	},
	"type": "module",
	"dependencies": {
		"@pyscript/core": "^0.4.32",
		"@sveltejs/adapter-node": "^1.3.1",
		"async": "^3.2.5",
		"bits-ui": "^0.19.7",
		"dayjs": "^1.11.10",
		"eventsource-parser": "^1.1.2",
		"file-saver": "^2.0.5",
		"highlight.js": "^11.9.0",
		"i18next": "^23.10.0",
		"i18next-browser-languagedetector": "^7.2.0",
		"i18next-resources-to-backend": "^1.2.0",
		"idb": "^7.1.1",
		"js-sha256": "^0.10.1",
		"katex": "^0.16.9",
		"marked": "^9.1.0",
		"mermaid": "^10.9.1",
		"pyodide": "^0.26.0-alpha.4",
		"socket.io-client": "^4.7.5",
		"sortablejs": "^1.15.2",
		"svelte-sonner": "^0.3.19",
		"tippy.js": "^6.3.7",
		"uuid": "^9.0.1"
	}
}
