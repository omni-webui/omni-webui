{
	"$schema": "https://biomejs.dev/schemas/1.8.1/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		},
		"ignore": [
			"**/node_modules/**",
			"**/dist/**",
			"**/build/**",
			".venv/**",
			".svelte-kit/**",
			".mypy_cache/**",
			"static/"
		]
	},
	"formatter": {
		"enabled": true,
		"ignore": [
			"**/node_modules/**",
			"**/dist/**",
			"**/build/**",
			".venv/**",
			".svelte-kit/**",
			".mypy_cache/**",
			"static/"
		],
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "none"
		}
	},
	"overrides": [
		{
			"include": ["*.svelte"],
			"linter": {
				"rules": {
					"style": {
						"useConst": "off"
					}
				}
			}
		}
	]
}
